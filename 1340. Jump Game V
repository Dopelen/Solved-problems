"""You can see the description of the task using the code specified in the title on leetcode.
This program has O(n ** 2) complexity by time and O(n) by space.

A challenging dynamic programming problem that I finally managed to solve myself.
Essentially, we simply need to recursively calculate for each cell the maximum number of jumps that can be made from it. 
Implicitly from the conditions, we can see that we avoid cycles thanks to the conditions; 
essentially, we have a limited number of jumps by the values, since we can only jump to smaller values; 
smaller values ​​can never jump to their parent. 
This allows us to avoid cycle-finding problems and simply perform a recursive traversal from each index (therefore, taking the maximum of all traversals).
"""

class Solution:
    def maxJumps(self, arr: List[int], d: int) -> int:
        size = len(arr)
        dp = [0] * size

        def calculate_dp(idx):
            if dp[idx] == 0:
                dp[idx] = 1
                for j in range(idx - 1, max(-1, idx - d - 1), -1):
                    if arr[j] >= arr[idx]:
                        break
                    dp[idx] = max(dp[idx], 1 + calculate_dp(j))
                for k in range(idx + 1, min(size, idx + d + 1)):
                    if arr[k] >= arr[idx]:
                        break
                    dp[idx] = max(dp[idx], 1 + calculate_dp(k))
            return dp[idx]

        for i in range(size):
            calculate_dp(i)
        return max(dp)
