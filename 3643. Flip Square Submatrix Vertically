# For
class Solution:
    def reverseSubmatrix(self, grid: List[List[int]], x: int, y: int, k: int) -> List[List[int]]:
        for i in range(k // 2):
            top = x + i
            bottom = x + k - 1 - i
            grid[top][y:y + k], grid[bottom][y:y + k] = grid[bottom][y:y + k], grid[top][y:y + k]
        return grid


# While
class Solution:
    def reverseSubmatrix(self, grid: List[List[int]], x: int, y: int, k: int) -> List[List[int]]:
        first, last = x, x + k - 1
        while first < last:
            grid[first][y:y + k], grid[last][y:y + k] = grid[last][y:y + k], grid[first][y:y + k]
            first += 1
            last -= 1
        return grid
