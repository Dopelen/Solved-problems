"""You can see the description of the task using the code specified in the title on leetcode.
This program has O(m + q) complexity by time and O(m + q) by space.

It’s an incredibly tricky problem, even though it’s just a continuation of yesterday’s.
A bit of thought reveals that we simply need to avoid double-counting overlapping intervals—but the question is: how do we do that?
The answer lies in using three different prefix arrays...
It’s the final boss of prefix sum problems!
The problem itself is cool, but I couldn't come up with the solution without a hint.
"""

class Solution:
    def sumAndMultiply(self, s: str, queries: List[List[int]]) -> List[int]:
        MOD = 10 ** 9 + 7
        pow10 = [1] * 100001
        for i in range(1, 100001):
            pow10[i] = pow10[i - 1] * 10 % MOD
        size_s = len(s)
        sum = [0] * (size_s + 1)
        x = [0] * (size_s + 1)
        cnt = [0] * (size_s + 1)
        for i, c in enumerate(s):
            d = int(c)
            sum[i + 1] = sum[i] + d
            x[i + 1] = (x[i] * 10 + d) % MOD if d > 0 else x[i]
            cnt[i + 1] = cnt[i] + (d > 0)

        size_q = len(queries)
        res = [0] * size_q
        for i in range(size_q):
            l = queries[i][0]
            r = queries[i][1] + 1
            length = cnt[r] - cnt[l]
            res[i] = (x[r] - x[l] * pow10[length]) * (sum[r] - sum[l]) % MOD

        return res
