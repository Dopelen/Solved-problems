# lib version
class Solution:
    def passwordStrength(self, password: str) -> int:
        security_score = 0
        for symbol in set(password):
            if symbol in "!#@$":
                security_score += 5
            elif symbol in digits:
                security_score += 3
            elif symbol in ascii_uppercase:
                security_score += 2
            elif symbol in ascii_lowercase:
                security_score += 1
        return security_score


# ASCII version 
class Solution:
    def passwordStrength(self, password: str) -> int:
        visited = set()
        security_score = 0
        for symbol in password:
            ascii_code = ord(symbol)
            if ascii_code not in visited:
                if 64 < ascii_code < 91:
                    security_score += 2
                elif 96 < ascii_code < 123:
                    security_score += 1
                elif 47 < ascii_code < 58:
                    security_score += 3
                elif ascii_code in (33, 35, 36, 64):
                    security_score += 5
                visited.add(ascii_code)
        return security_score
