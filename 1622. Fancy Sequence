# Initial TLE solution 
class Fancy:

    def __init__(self):
        self.MOD = 10 ** 9 + 7
        self.values = []
        self.operations = []

    def append(self, val: int) -> None:
        self.values.append([val, len(self.operations)])

    def addAll(self, inc: int) -> None:
        self.operations.append((0, inc))

    def multAll(self, m: int) -> None:
        self.operations.append((1, m))

    def getIndex(self, idx: int) -> int:
        if idx >= len(self.values):
            return -1

        cur_val, op_idx = self.values[idx]

        for op, val in self.operations[op_idx:]:
            if op == 0:
                cur_val = (cur_val + val) % self.MOD
            else:
                cur_val = (cur_val * val) % self.MOD

        self.values[idx] = [cur_val, len(self.operations)]

        return cur_val
