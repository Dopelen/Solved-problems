"""You can see the description of the task using the code specified in the title on leetcode.
 This program has O(n * m) complexity by time and O(n * m).

A pleasant problem. 
It didn't turn out very beautifully, but overall I'm happy.
To avoid recalculating all possible paths, I entered the "maximum positive and maximum negative values" for each cell. 
If we arrive at a cell and there was something larger there, we can stop traversing it as non-optimal — all subsequent paths are the same, but the current value is worse. 
The same applies to negative values, because they can be converted to positive values, in which case we remember the smallest of the previous ones.
"""


# Initial Solution (all path with optimization)
class Solution:
    def maxProductPath(self, grid: List[List[int]]) -> int:
        MOD = 10 ** 9 + 7
        rows, cols = len(grid), len(grid[0])
        stack = [(0, 0, 1)]
        dp = [[(math.inf, -math.inf) for _ in range(cols)] for _ in range(rows)]
        zero_in_grid = False
        while stack:
            y, x, cur_val = stack.pop()
            new_val = cur_val * grid[y][x]
            if new_val == 0: zero_in_grid = True
            mn, mx = dp[y][x]
            if mn <= new_val <= mx:
                continue
            dp[y][x] = (min(mn, new_val), max(mx, new_val))
            if x + 1 < cols:
                stack.append((y, x + 1, new_val))
            if y + 1 < rows:
                stack.append((y + 1, x, new_val))
        result = dp[-1][-1][1]
        if result > 0:
            return result % MOD
        return 0 if zero_in_grid else -1


# Correct DP solution
class Solution:
    def maxProductPath(self, grid: List[List[int]]) -> int:
        MOD = 10**9 + 7
        rows, cols = len(grid), len(grid[0])
        dp_max = [[0] * cols for _ in range(rows)]
        dp_min = [[0] * cols for _ in range(rows)]
        dp_max[0][0] = dp_min[0][0] = grid[0][0]
        for j in range(1, cols):
            dp_max[0][j] = dp_min[0][j] = dp_max[0][j - 1] * grid[0][j]
        for i in range(1, rows):
            dp_max[i][0] = dp_min[i][0] = dp_max[i - 1][0] * grid[i][0]
        for i in range(1, rows):
            for j in range(1, cols):
                val = grid[i][j]
                candidates = (
                    dp_max[i - 1][j] * val,
                    dp_min[i - 1][j] * val,
                    dp_max[i][j - 1] * val,
                    dp_min[i][j - 1] * val,
                )
                dp_max[i][j] = max(candidates)
                dp_min[i][j] = min(candidates)
        result = dp_max[-1][-1]
        return result % MOD if result >= 0 else -1
