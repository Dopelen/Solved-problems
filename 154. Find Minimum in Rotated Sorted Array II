"""You can see the description of the task using the code specified in the title on leetcode.
This program has O(log(n)) complexity by time and O(1) by space.

Introducing duplicates made the problem more difficult than I thought!
Here we can use a divide and conquer approach, continuing to split the array into halves until they are sorted.

A very beautiful solution!
"""

class Solution:
    def findMin(self, nums: List[int]) -> int:
        def dnc(left: int, right: int) -> int:
            if left == right:
                return nums[left]
            if nums[left] < nums[right]:
                return nums[left]
            m = (left + right) // 2
            return min(dnc(left, m), dnc(m + 1, right))
        return dnc(0, len(nums) - 1)
