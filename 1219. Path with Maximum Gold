#!/usr/bin/python
"""You can see the description of the task using the code specified in the title on leetcode.
This program has O(n * m) complexity by time and O(n * m) by space.

For some reason, I assumed I could enter the cells a second time, so I initially made a slightly incorrect decision. 
Luckily, rewriting the loop to use backtracking wasn't difficult.
"""

class Solution:
    def getMaximumGold(self, grid: List[List[int]]) -> int:
        rows, cols = len(grid), len(grid[0])
        d = [(-1, 0), (1, 0), (0, -1), (0, 1)]
        max_profit = 0

        def dfs(y, x):
            if grid[y][x] == 0:
                return 0
            gold = grid[y][x]
            grid[y][x] = 0
            best = 0
            for dy, dx in d:
                ny, nx = y + dy, x + dx
                if 0 <= ny < rows and 0 <= nx < cols:
                    best = max(best, dfs(ny, nx))
            grid[y][x] = gold
            return gold + best

        for r in range(rows):
            for c in range(cols):
                if grid[r][c] > 0:
                    max_profit = max(max_profit, dfs(r, c))

        return max_profit
