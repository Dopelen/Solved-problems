# https://leetcode.com/problems/beautiful-array/solutions/186679/odd-even-pattern-on-by-lee215-bc39/
class Solution:
    def beautifulArray(self, N):
        res = [1]
        while len(res) < N:
            res = [i * 2 - 1 for i in res] + [i * 2 for i in res]
        return [i for i in res if i <= N]
