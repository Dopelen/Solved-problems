# The real solution is to search for neighbors for each index using binsearch.
class Solution:
    def solveQueries(self, nums: List[int], queries: List[int]) -> List[int]:
        size_num = len(nums)
        answer = []
        num_to_idx = defaultdict(list)

        for idx, elem in enumerate(nums):
            num_to_idx[elem].append(idx)

        for q in queries:
            cur_val = nums[q]
            if len(num_to_idx[cur_val]) < 2:
                answer.append(-1)
                continue
            cur_pos = bisect.bisect_left(num_to_idx[cur_val], q)
            distance_left = (q - num_to_idx[cur_val][cur_pos - 1]) if (cur_pos != 0) else (q + size_num - num_to_idx[cur_val][-1])
            distance_right = (num_to_idx[cur_val][0] + (size_num - q)) if (cur_pos + 1 == len(num_to_idx[cur_val])) else (num_to_idx[cur_val][cur_pos + 1] - q)
            answer.append(min(distance_left, distance_right))

        return answer


