"""You can see the description of the task using the code specified in the title on leetcode.
This program has O(m * log(m)) complexity by time and O(m * log(m)) by space.

The task is complex, but doable. 
The main challenge is finding a workaround that will give us a correct answer with constraints of 10 ** 9.
The key trick is calculating the required achievable heights in two passes and then 
finding the "peak" between adjacent heights to create the maximum possible elevation between adjacent constraints.
"""

class Solution:
    def maxBuilding(self, n: int, restrictions: List[List[int]]) -> int:
        restrictions.append([1, 0])
        restrictions.sort()
        if restrictions[-1][0] != n:
            restrictions.append([n, n - 1])
        size = len(restrictions)
        for i in range(1, size):
            restrictions[i][1] = min(restrictions[i][1], restrictions[i - 1][1] + (restrictions[i][0] - restrictions[i - 1][0]))
        for i in range(size - 2, 0, -1):
            restrictions[i][1] = min(restrictions[i][1], restrictions[i + 1][1] + (restrictions[i + 1][0] - restrictions[i][0]))
        answer = 0
        for i in range(size - 1):
            best = ((restrictions[i + 1][0] - restrictions[i][0]) + restrictions[i][1] + restrictions[i + 1][1]) // 2
            answer = max(answer, best)
        return answer
