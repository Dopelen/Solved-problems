#!/usr/bin/python
"""You can see the description of the task using the code specified in the title on leetcode.
This program has O(n) complexity by time and O(1) by space.

A simple and straightforward array traversal.
We mark visited points and, from each, construct two new potential ones until we find 0.
"""

# After refactoring
class Solution:
    def canReach(self, arr: List[int], start: int) -> bool:
        stack = [start]
        while stack:
            i = stack.pop()
            if arr[i] == 0:
                return True
            jump = arr[i]
            arr[i] = -1
            for nxt in (i - jump, i + jump):
                if 0 <= nxt < len(arr) and arr[nxt] >= 0:
                    stack.append(nxt)
        return False

# Initial Solution
class Solution:
    def canReach(self, arr: List[int], start: int) -> bool:
        size = len(arr)
        processed = set()
        process = [start]
        while process:
            cur_idx = process.pop()
            if arr[cur_idx] == 0:
                return True
            left_idx = cur_idx - arr[cur_idx]
            right_idx = cur_idx + arr[cur_idx]
            if left_idx >= 0 and left_idx not in processed:
                process.append(left_idx)
            if right_idx < size and right_idx not in processed:
                process.append(right_idx)
            processed.add(cur_idx)
        return False
