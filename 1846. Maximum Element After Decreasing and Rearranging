"""You can see the description of the task using the code specified in the title on leetcode.
This program has O(n * log(n)) complexity by time and O(n) by space.

A very enjoyable problem; I arrived at the solution simply by thinking about it while lying in bed.
Since the number of operations isn't a concern and we want to construct the largest possible sequence, we can use a greedy approach starting from the smallest number 
(sorting the list first). 
We then look for a larger number in the list that can be reduced to the next required element. 
(I have a bit of an unhealthy obsession with reversing lists to pop the last element in O(1) time and use while instead of 'for'—which is what I did initially—
but simply using index-based traversal would actually suffice)
"""

# After refactoring
class Solution:
    def maximumElementAfterDecrementingAndRearranging(self, arr: List[int]) -> int:
        ans = 1
        arr.sort()
        for idx in range(1, len(arr)):
            if arr[idx] > ans:
                ans += 1
        return ans


# Initial solution
class Solution:
    def maximumElementAfterDecrementingAndRearranging(self, arr: List[int]) -> int:
        prev_val = idx = 0
        arr.sort()
        while idx < len(arr):
            if arr[idx] > prev_val:
                new_val = prev_val + 1
                prev_val = new_val
            idx += 1
        return prev_val
