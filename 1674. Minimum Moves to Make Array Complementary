"""You can see the description of the task using the code specified in the title on leetcode.
This program has O(n + l) complexity by time and O(n + l) by space.

I started by simply counting frequencies, but at some point, it dawned on me that I could build an array that would take into account the ranges of variation for each sum.
But I still couldn't figure out how to program this elegantly.
I feel like it's been a long time since I've solved a problem using a difference array.
"""

# https://leetcode.com/problems/minimum-moves-to-make-array-complementary/editorial/?envType=daily-question&envId=2026-05-13
class Solution:
    def minMoves(self, nums: List[int], limit: int) -> int:
        size = len(nums)
        diff = [0] * (2 * limit + 2)
        for i in range(size // 2):
            a = nums[i]
            b = nums[size - 1 - i]
            x = min(a, b)
            y = max(a, b)
            diff[2] += 2
            diff[2 * limit + 1] -= 2
            diff[x + 1] -= 1
            diff[y + limit + 1] += 1
            diff[a + b] -= 1
            diff[a + b + 1] += 1
        ans = math.inf
        cur = 0
        for s in range(2, 2 * limit + 1):
            cur += diff[s]
            ans = min(ans, cur)
        return ans
