"""You can see the description of the task using the code specified in the title on leetcode.
This program has O(n) complexity by time and  O(n) by space.

I have already solved a typical problem (105), here it was only necessary to change the order of traversal and from which side we take the next element.
"""

class Solution:
    def buildTree(self, inorder: List[int], postorder: List[int]) -> Optional[TreeNode]:
        mapping = {val: i for i, val in enumerate(inorder)}

        def build(start, end):
            if start > end:
                return None
            root = TreeNode(postorder.pop())
            mid = mapping[root.val]
            root.right = build(mid + 1, end)
            root.left = build(start, mid - 1)
            return root

        return build(0, len(inorder) - 1)
