# Correct simple DP solution
class Solution:
    def maximumJumps(self, nums: List[int], target: int) -> int:
        size = len(nums)
        dp = [-1] * len(nums)
        dp[0] = 0
        for i in range(size):
            if dp[i] == -1:
                continue
            for j in range(i + 1, size):
                if (abs(nums[j] - nums[i]) <= target):
                    dp[j] = max(dp[i] + 1, dp[j])
        return dp[-1]


# madskills with generators (I think its my first ever solution with generator!)
class Solution:
    def maximumJumps(self, nums: List[int], target: int) -> int:
        size = len(nums)
        dp = [-1] * size
        dp[0] = 0

        def process_idx(idx):
            for j in range(idx + 1, size):
                if abs(nums[j] - nums[idx]) <= target:
                    if dp[idx] + 1 > dp[j]:
                        dp[j] = dp[idx] + 1
                        yield j

        heap = []
        start_gen = process_idx(0)
        heappush(heap, (-dp[0], 0, start_gen))
        while heap:
            neg_steps, idx, gen = heappop(heap)
            try:
                nxt = next(gen)
                heappush(heap, (neg_steps, idx, gen))
                new_gen = process_idx(nxt)
                heappush(heap, (-dp[nxt], nxt, new_gen))
            except StopIteration:
                pass
        return dp[-1]


# Naive TLE solution with heap
class Solution:
    def maximumJumps(self, nums: List[int], target: int) -> int:
        size = len(nums)
        dp = [-1] * len(nums)
        dp[0] = 0
        heap = [(0, 0)]
        heapify(heap)

        def process_idx(steps, idx):
            for j in range(idx + 1, size):
                if (-target <= nums[j] - nums[idx] <= target) and (dp[idx] + 1 > dp[j]):
                    dp[j] = dp[idx] + 1
                    heappush(heap, ((steps - 1), j))

        while heap:
            steps, index = heappop(heap)
            if dp[index] >= -steps:
                process_idx(steps, index)

        return dp[-1]
