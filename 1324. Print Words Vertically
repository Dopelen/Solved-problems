"""You can see the description of the task using the code specified in the title on leetcode.
This program has O(n) complexity by time and O(n) by space.

The task isn't difficult, but it does require some structure. 
Overall, I enjoyed solving it; 
I simply had to sit down and write out the process for constructing the columns, and in the end, I even managed to do it in one pass.
"""

class Solution:
    def printVertically(self, s: str) -> List[str]:
        process = s.split(" ")
        max_length = max(len(word) for word in process)
        columns = [[" "] * len(process) for _ in range(max_length)]
        for word_idx, word in enumerate(process):
            for symbol_idx, symbol in enumerate(word):
                columns[symbol_idx][word_idx] = symbol
        return [''.join(col).rstrip() for col in columns]

