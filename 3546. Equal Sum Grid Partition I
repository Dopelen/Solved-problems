# Initial Solution
class Solution:
    def canPartitionGrid(self, grid: List[List[int]]) -> bool:
        rows, cols = len(grid), len(grid[0])
        prefix_grid = copy.deepcopy(grid)
        for y in range(rows):
            for x in range(cols):
                prefix_col = prefix_grid[y][x - 1] if x > 0 else 0
                prefix_row = prefix_grid[y - 1][x] if y > 0 else 0
                cur_sum = prefix_col + prefix_row + grid[y][x] - (
                    prefix_grid[y - 1][x - 1] if (y > 0 and x > 0) else 0)
                prefix_grid[y][x] = cur_sum

        def diff(idx, vert):
            if vert:
                first_section = prefix_grid[-1][idx]
            else:
                first_section = prefix_grid[idx][-1]
            second_section = prefix_grid[-1][-1] - first_section
            difference = second_section - first_section
            return difference

        def check(l, r, vert):
            mid = (l + r) // 2
            while l <= r:
                comparison_result = diff(mid, vert)
                if comparison_result < 0:
                    r = mid - 1
                elif comparison_result > 0:
                    l = mid + 1
                else:
                    return True
                mid = (l + r) // 2

        if check(0, rows, False) or check(0, cols, True):
            return True
        return False


# There's a cool, simpler solution. The function grows monotonically, so we can simply calculate the sum of the rows and columns without prefixes, knowing the total sum.
# Cool, optimal solution
class Solution:
    def canPartitionGrid(self, grid: List[List[int]]) -> bool:
        rows, cols = len(grid), len(grid[0])
        
        total = sum(sum(row) for row in grid)
        
        cur = 0
        for r in range(rows - 1):
            cur += sum(grid[r])
            if cur * 2 == total:
                return True
        
        col_sums = [0] * cols
        for r in range(rows):
            for c in range(cols):
                col_sums[c] += grid[r][c]
        
        cur = 0
        for c in range(cols - 1):
            cur += col_sums[c]
            if cur * 2 == total:
                return True
        
        return False
