"""You can see the description of the task using the code specified in the title on leetcode.
This program has O(n) complexity by time and O(n) by space.

A nice pointer problem. 
For some reason, I initially tried to calculate prefixes, but then realized it was simpler and clearer to solve using two pointers. 
I struggled a bit with how to correctly calculate the loop, and finally won.
"""


# After refactoring (A clever trick! The window stores not the longest valid window, but the longest valid window it has encountered before!)
class Solution:
    def longestOnes(self, nums: List[int], k: int) -> int:
        left = zeros = 0
        for right, num in enumerate(nums):
            zeros += num == 0

            if zeros > k:
                zeros -= nums[left] == 0
                left += 1
        return len(nums) - left


# Initial Solution
class Solution:
    def longestOnes(self, nums: List[int], k: int) -> int:
        left = right = consecutive_ones = max_consecutive_ones = 0
        k_left = k
        while right != len(nums):
            if nums[right] != 1:
                if k_left:
                    k_left -= 1
                else:
                    while nums[left] != 0:
                        consecutive_ones -= 1
                        left += 1
                    consecutive_ones -= 1
                    left += 1
            consecutive_ones += 1
            right += 1
            max_consecutive_ones = max(max_consecutive_ones,consecutive_ones)
        return max_consecutive_ones
