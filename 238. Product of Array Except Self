"""You can see the description of the task using the code specified in the title on leetcode.
 This program has O(n) complexity by time and O(n).

The problem is literally "divide without using division."
Surprisingly, the problem has a beautiful and clear solution, as indicated by the problem statement itself.
Simply use prefix and suffix arrays to multiply all elements except the current one.
"""

class Solution:
    def productExceptSelf(self, nums: List[int]) -> List[int]:
        size = len(nums)
        prefix = [0] * size
        suffix = [0] * size
        prefix[0] = 1
        suffix[-1] = 1
        for i in range(1, size):
            prefix[i] = nums[i - 1] * prefix[i - 1]
        for j in range(size - 2, -1, -1):
            suffix[j] = suffix[j + 1] * nums[j + 1]
        return [prefix[a] * suffix[a] for a in range(size)]


# You can use one array, this will reduce memory a little
class Solution:
    def productExceptSelf(self, nums: List[int]) -> List[int]:
        n = len(nums)
        res = [1] * n
        pref = 1
        for i in range(n):
            res[i] = pref
            pref *= nums[i]
        suff = 1
        for i in range(n - 1, -1, -1):
            res[i] *= suff
            suff *= nums[i]
        return res
