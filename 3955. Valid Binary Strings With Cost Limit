"""You can see the description of the task using the code specified in the title on leetcode.
This program has O(n) complexity by time and  O(n) by space.

Once you’ve mastered recursion and backtracking, writing the solution isn't too difficult. 
The constraints are small, so I decided to work directly with strings rather than array elements for optimization.
"""

# without backtracking
class Solution:
    def generateValidStrings(self, n: int, k: int) -> list[str]:
        answer: list = []

        def construct_answer(idx: int, cost: int, values: str) -> None:
            if cost > k:
                return
            if idx == n:
                answer.append(values)
                return
            if values[idx - 1] != '1':
                construct_answer(idx + 1, cost + idx, values[0:idx] + "1" + values[idx + 1:])
            construct_answer(idx + 1, cost, values)

        construct_answer(0, 0, "0" * n)
        return answer


# with backtracking (somehow slower)
class Solution:
    def generateValidStrings(self, n: int, k: int) -> list[str]:
        answer: list = []
        cur_string: list = ["0"] * n

        def construct_answer(idx: int, cost: int) -> None:
            if cost > k:
                return
            if idx == n:
                answer.append("".join(cur_string))
                return

            construct_answer(idx + 1, cost)

            if idx == 0 or cur_string[idx - 1] == '0':
                cur_string[idx] = '1'
                construct_answer(idx + 1, cost + idx)
                cur_string[idx] = '0'

        construct_answer(0, 0)
        return answer
